{
  "name": "secondhand-backend",
  "version": "1.0.0",
  "description": "Backend API for second-hand selling web app",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "prisma:generate": "prisma generate",
    "prisma:db": "prisma db push",
    "prisma:studio": "prisma studio",
    "test": "cross-env NODE_ENV=test DATABASE_URL=file:./test.db node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "cross-env NODE_ENV=test node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.991.0",
    "@aws-sdk/s3-request-presigner": "^3.991.0",
    "@prisma/client": "^6.15.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "redis": "^4.7.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "prisma": "^6.15.0",
    "supertest": "^7.2.2"
  }
}
