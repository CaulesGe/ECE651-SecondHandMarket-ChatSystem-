generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String                     @id
  name         String
  email        String                     @unique
  password     String
  role         String
  createdAt    DateTime
  address      String?
  phone        String?
  gender       String?
  transactions Transaction[]
  chatParticipants ConversationParticipant[]
  chatMessages Message[]
  chatReadStates ConversationReadState[]
  drafts       Draft[]
  favorites             Favorite[]
  emailVerified       Boolean  @default(false)
  verificationToken   String?  @unique
  verificationExpires DateTime?
  reviewsWritten  TradeReview[] @relation("TradeReviewWriter")
  reviewsReceived TradeReview[] @relation("TradeReviewReceiver")
}

model Goods {
  id          String   @id
  title       String
  description String?
  price       Float
  condition   String
  category    String
  images      String?
  sellerId    String?
  sellerName  String
  location    String
  listedAt    DateTime
  quantity     Int      @default(1)
  status      String   @default("available") // available | sold
  soldAt      DateTime?
  soldToUserId String?
  favorites   Favorite[]
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    String
  goodsId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goods     Goods    @relation(fields: [goodsId], references: [id], onDelete: Cascade)

  @@unique([userId, goodsId])
  @@index([userId, createdAt])
  @@index([goodsId])
}

model Draft {
  id          String   @id
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  description String?
  price       Float?
  condition   String?
  category    String?
  images      String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, updatedAt])
}

model Transaction {
  id        String            @id
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  total     Float
  status    String
  createdAt DateTime
  last4     String?
  items     TransactionItem[]
  reviews   TradeReview[]
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  goodsId       String
  title         String
  price         Float
  quantity      Int
  sellerId      String?
  sellerName    String?

  reviews       TradeReview[]
}

model TradeReview {
  id                String   @id @default(cuid())
  transactionId     String
  transactionItemId Int
  reviewerId        String
  revieweeId        String
  direction         String   // BUYER_TO_SELLER | SELLER_TO_BUYER
  rating            Int
  comment           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transaction       Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionItem   TransactionItem @relation(fields: [transactionItemId], references: [id], onDelete: Cascade)
  reviewer          User            @relation("TradeReviewWriter", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee          User            @relation("TradeReviewReceiver", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([transactionItemId, direction])
  @@index([reviewerId, createdAt])
  @@index([revieweeId, createdAt])
}

model Conversation {
  id        String                     @id @default(cuid())
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  contextOrderId String?
  contextItemId  String?
  participants   ConversationParticipant[]
  messages       Message[]
  readStates     ConversationReadState[]
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  senderId        String
  type            String
  content         String?
  mediaObjectKey  String?
  isWithdrawn     Boolean      @default(false)
  withdrawnAt     DateTime?
  clientMessageId String
  createdAt       DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  sender          User         @relation(fields: [senderId], references: [id])

  @@unique([conversationId, senderId, clientMessageId])
  @@index([conversationId, createdAt])
}

model ConversationReadState {
  id                Int          @id @default(autoincrement())
  conversationId    String
  userId            String
  lastReadMessageId String?
  lastReadMessageCreatedAt DateTime?
  readAt            DateTime?
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  user              User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}
